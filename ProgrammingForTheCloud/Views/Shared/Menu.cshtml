@model IEnumerable<ProgrammingForTheCloud.Models.MenuItem>

@{
    ViewData["Title"] = "Restaurant Menu";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Restaurant Menu</h2>
        <div>
            <a asp-action="Index" class="btn btn-outline-secondary">Back to Restaurants</a>
            <a asp-action="CreateMenu" asp-route-restaurantId="@ViewBag.RestaurantId" class="btn btn-primary">
                + Add New Item
            </a>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info">
            This restaurant doesn't have any menu items yet. Click "+ Add New Item" to get started!
        </div>
    }
    else
    {
        <div class="card shadow-sm">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                <tr>
                    <th>Name</th>
                    <th>Category</th>
                    <th>Description</th>
                    <th class="text-end">Price</th>
                </tr>
                </thead>
                <tbody>
                @foreach (var item in Model)
                {
                    @* <tr> *@
                    @*     <td class="fw-bold">@item.Name</td> *@
                    @*     <td><span class="badge bg-info text-dark">@item.Category</span></td> *@
                    @*     <td class="text-muted">@item.Description</td> *@
                    @*     <td class="text-end fw-bold text-success"> *@
                    @*         @item.Price.ToString("C") </td> *@
                    @* </tr> *@
                }
                </tbody>
            </table>
        </div>
    }
</div>