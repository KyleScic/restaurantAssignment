@{
    ViewData["Title"] = "Home Page";
}

<div class="text-center">
    <h1 class="display-4">Welcome to the Cloud Restaurant Manager</h1>
    <p>Manage your menus and locations all in one place.</p>
    
    <a asp-controller="Restaurant" asp-action="Create" class="btn btn-primary mt-3">
        + Add a New Restaurant
    </a>

    
    <table class="table">
        <thead>
        <tr>
            <th>Name</th>
            <th>Cuisine</th>
            <th>Actions</th>
        </tr>
        </thead>
        <tbody>
        @foreach (var restaurant in Model)
        {
            <tr>
                <td>@restaurant.Name</td>
                <td>@restaurant.Cuisine</td>
                <td>
                    <a asp-action="Menu" asp-route-id="@restaurant.Id" class="btn btn-primary">
                        View Menu
                    </a>
                    
                    <a asp-controller="Restaurant" asp-action="CreateMenu" asp-route-restaurantId="@restaurant.Id" class="btn btn-primary">
                        + Add Menu Item
                    </a>
                </td>
            </tr>
        }
        </tbody>
    </table>
    
   
</div>