@model ProgrammingForTheCloud.Models.Restaurant

@{
    ViewData["Title"] = "Add Restaurant";
}

<div class="container mt-4">
    <h2>Add a New Restaurant</h2>
    <hr />

    <div class="row">
        <div class="col-md-6">
            <form asp-action="Create" method="post">
                
                <div class="mb-3">
                    <label asp-for="Name" class="form-label">Restaurant Name</label>
                    <input asp-for="Name" class="form-control" required placeholder="e.g., Luqa Pizza House" />
                </div>

                <div class="mb-3">
                    <label asp-for="Cuisine" class="form-label">Cuisine Type</label>
                    <input asp-for="Cuisine" class="form-control" required placeholder="e.g., Italian, Asian, Fast Food" />
                </div>

                <div class="mb-3">
                    <label asp-for="Address" class="form-label">Address</label>
                    <input asp-for="Address" class="form-control" required />
                </div>

                <button type="submit" class="btn btn-success">Save to Cloud</button>
                <a asp-action="Index" class="btn btn-secondary ms-2">Cancel</a>
            </form>
        </div>
    </div>
</div>