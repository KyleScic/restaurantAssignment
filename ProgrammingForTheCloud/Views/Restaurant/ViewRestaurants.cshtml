@model IEnumerable<ProgrammingForTheCloud.Models.Restaurant>

@{
    ViewData["Title"] = "All Restaurants";
}

<h1>Restaurants</h1>

<table class="table">
    <thead>
    <tr>
        <th>Name</th>
        <th>Cuisine</th>
        <th>Actions</th> 
    </tr>
    </thead>
    <tbody>
    @foreach (var restaurant in Model)
    {
        <tr>
            <td>@restaurant.Name</td>
            <td>@restaurant.Cuisine</td>
                
            <td>
                <a asp-action="Menu" asp-route-id="@restaurant.Id" class="btn btn-outline-primary me-2">
                    View Menu
                </a>
                    
                <a asp-action="CreateMenu" asp-route-restaurantId="@restaurant.Id" class="btn btn-primary">
                    + Add Menu Item
                </a>
            </td>
        </tr>
    }
    </tbody>
</table>